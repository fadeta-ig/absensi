generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Employee {
  id                String                     @id @default(uuid())
  employeeId        String                     @unique @map("employee_id")
  name              String
  email             String                     @unique
  phone             String
  departmentId      String                     @map("department_id")
  divisionId        String?                    @map("division_id")
  positionId        String                     @map("position_id")

  departmentRel     Department                 @relation("EmployeeDepartment", fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  divisionRel       Division?                  @relation("EmployeeDivision", fields: [divisionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  positionRel       Position                   @relation("EmployeePosition", fields: [positionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  role              String                     @default("employee")
  gender            String                     @default("Laki-Laki")
  password          String
  faceDescriptor    String?                    @map("face_descriptor") @db.LongText
  joinDate          DateTime                   @map("join_date")
  totalLeave        Int                        @default(12) @map("total_leave")
  usedLeave         Int                        @default(0) @map("used_leave")
  avatarUrl         String?                    @map("avatar_url")
  isActive          Boolean                    @default(true) @map("is_active")
  shiftId           String?                    @map("shift_id")
  bypassLocation    Boolean                    @default(false) @map("bypass_location")
  basicSalary       Float                      @default(0) @map("basic_salary")
  managerId         String?                    @map("manager_id")
  attendances       AttendanceRecord[]
  payrollComponents EmployeePayrollComponent[]
  manager           Employee?                  @relation("Hierarchy", fields: [managerId], references: [employeeId])
  subordinates      Employee[]                 @relation("Hierarchy")
  shift             WorkShift?                 @relation(fields: [shiftId], references: [id])
  leaves            LeaveRequest[]
  overtimes         OvertimeRequest[]
  payslips          PayslipRecord[]
  todos             TodoItem[]
  visits            VisitReport[]
  locations         Location[]                 @relation("employeelocations")
  pushSubscriptions PushSubscription[]
  assignedAssets    Asset[]

  @@index([managerId], map: "employees_manager_id_fkey")
  @@index([shiftId], map: "employees_shift_id_fkey")
  @@map("employees")
}

model PushSubscription {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  endpoint   String   @unique @db.VarChar(500)
  p256dh     String   @db.Text
  auth       String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  employee   Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@index([employeeId], map: "push_subscriptions_employee_id_fkey")
  @@map("push_subscriptions")
}

model VisitReport {
  id             String    @id @default(uuid())
  employeeId     String    @map("employee_id")
  date           DateTime
  visitStartTime DateTime? @map("visit_start_time")
  visitEndTime   DateTime? @map("visit_end_time")
  clientName     String    @map("client_name")
  clientAddress String   @map("client_address") @db.Text
  purpose       String   @db.Text
  result        String?  @db.Text
  location      String?  @db.LongText
  photo         String?  @db.LongText
  status        String   @default("pending")
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  employee      Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@index([employeeId], map: "visit_reports_employee_id_fkey")
  @@map("visit_reports")
}

model AttendanceRecord {
  id               String    @id @default(uuid())
  employeeId       String    @map("employee_id")
  date             DateTime
  clockIn          DateTime? @map("clock_in")
  clockOut         DateTime? @map("clock_out")
  clockInLocation  String?   @map("clock_in_location") @db.LongText
  clockOutLocation String?   @map("clock_out_location") @db.LongText
  clockInPhoto     String?   @map("clock_in_photo") @db.LongText
  clockOutPhoto    String?   @map("clock_out_photo") @db.LongText
  status           String    @default("present")
  notes            String?   @db.Text
  employee         Employee  @relation(fields: [employeeId], references: [employeeId], onDelete: Restrict)

  @@unique([employeeId, date])
  @@map("attendance_records")
}

model PayslipRecord {
  id          String   @id @default(uuid())
  employeeId  String   @map("employee_id")
  period      String
  basicSalary Float    @map("basic_salary")
  allowances  String   @db.LongText
  deductions  String   @db.LongText
  overtime    Float    @default(0)
  netSalary   Float    @map("net_salary")
  issuedDate  DateTime @map("issued_date")
  notes       String?  @db.Text
  employee    Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Restrict)

  @@index([employeeId], map: "payslip_records_employee_id_fkey")
  @@unique([employeeId, period])
  @@map("payslip_records")
}

model WorkShift {
  id            String         @id @default(uuid())
  name          String
  isDefault     Boolean        @default(false) @map("is_default")
  earlyCheckIn  Int            @default(0) @map("early_check_in")
  earlyCheckOut Int            @default(0) @map("early_check_out")
  lateCheckIn   Int            @default(0) @map("late_check_in")
  lateCheckOut  Int            @default(0) @map("late_check_out")
  employees     Employee[]
  days          WorkShiftDay[]

  @@map("work_shifts")
}

model WorkShiftDay {
  id        String    @id @default(uuid())
  shiftId   String    @map("shift_id")
  dayOfWeek Int       @map("day_of_week")
  startTime String    @map("start_time")
  endTime   String    @map("end_time")
  isOff     Boolean   @default(false) @map("is_off")
  shift     WorkShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([shiftId, dayOfWeek])
  @@map("work_shift_days")
}

model LeaveRequest {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  type       String
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  reason     String   @db.Text
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")
  attachment String?  @db.LongText
  employee   Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Restrict)

  @@index([employeeId], map: "leave_requests_employee_id_fkey")
  @@map("leave_requests")
}

model NewsItem {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  category  String   @default("general")
  author    String
  createdAt DateTime @default(now()) @map("created_at")
  isPinned  Boolean  @default(false) @map("is_pinned")
  mediaName String?  @map("media_name")
  mediaUrl  String?  @map("media_url")

  @@map("news_items")
}

model TodoItem {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  text       String   @db.Text
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  employee   Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@index([employeeId], map: "todo_items_employee_id_fkey")
  @@map("todo_items")
}

model OvertimeRequest {
  id            String   @id @default(uuid())
  employeeId    String   @map("employee_id")
  date          DateTime
  startTime     DateTime @map("start_time")
  endTime       DateTime @map("end_time")
  hours         Float
  approvedHours Float?   @map("approved_hours")
  isHoliday     Boolean  @default(false) @map("is_holiday")
  overtimePay   Float    @default(0) @map("overtime_pay")
  reason        String   @db.Text
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")
  employee      Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Restrict)

  @@index([employeeId], map: "overtime_requests_employee_id_fkey")
  @@map("overtime_requests")
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String?  @unique
  description String?  @db.Text
  divisionId  String   @map("division_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  division    Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  employees   Employee[] @relation("EmployeeDepartment")

  @@index([divisionId], map: "departments_division_id_fkey")
  @@map("departments")
}

model Division {
  id          String       @id @default(uuid())
  name        String       @unique
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  departments Department[]
  employees   Employee[]   @relation("EmployeeDivision")

  @@map("divisions")
}

model Position {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  employees Employee[] @relation("EmployeePosition")

  @@map("positions")
}

model PayrollComponent {
  id                 String                     @id @default(uuid())
  name               String                     @unique
  type               String
  defaultAmount      Float                      @default(0) @map("default_amount")
  isActive           Boolean                    @default(true) @map("is_active")
  description        String?                    @db.Text
  createdAt          DateTime                   @default(now()) @map("created_at")
  employeeComponents EmployeePayrollComponent[]

  @@map("payroll_components")
}

model EmployeePayrollComponent {
  id          String           @id @default(uuid())
  employeeId  String           @map("employee_id")
  componentId String           @map("component_id")
  amount      Float            @default(0)
  component   PayrollComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  employee    Employee         @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@unique([employeeId, componentId])
  @@index([componentId], map: "employee_payroll_components_component_id_fkey")
  @@map("employee_payroll_components")
}

model Location {
  id        String     @id @default(uuid())
  name      String     @unique
  latitude  Float
  longitude Float
  radius    Float      @default(100)
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  employees Employee[] @relation("employeelocations")

  @@map("locations")
}

// ─── Asset Management ──────────────────────────────────────────

model AssetCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  prefix      String
  createdAt   DateTime @default(now()) @map("created_at")

  assets      Asset[]

  @@map("asset_categories")
}

enum AssetKondisi {
  BAIK
  KURANG_BAIK
  RUSAK
}

enum AssetStatus {
  AVAILABLE      // Di GA pool — siap dipinjamkan
  IN_USE         // Sedang dipegang seseorang
  MAINTENANCE    // Sedang diperbaiki
  RETIRED        // Tidak layak pakai
  COMPANY_OWNED  // Milik perusahaan (ex-lelang), hidden dari HR
}

enum HolderType {
  EMPLOYEE        // Karyawan aktif
  FORMER_EMPLOYEE // Mantan karyawan (nama tetap disimpan)
  TEAM            // Dipegang tim (Warehouse, Creative, dll)
  GA_POOL         // Di brankas GA — aset bebas
  COMPANY_OWNED   // Milik perusahaan
}

model Asset {
  id             String        @id @default(uuid())
  assetCode      String        @unique @map("asset_code")
  name           String
  
  categoryId     String        @map("category_id")
  categoryRel    AssetCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  serialNumber   String?       @map("serial_number")
  imei           String?       @map("imei")
  manufacturer   String?
  modelName      String?       @map("model_name")
  
  purchaseDate   DateTime?     @map("purchase_date")
  purchasePrice  Float?        @map("purchase_price")
  warrantyExpiry DateTime?     @map("warranty_expiry")
  kondisi        AssetKondisi  @default(BAIK)
  status         AssetStatus   @default(AVAILABLE)
  holderType     HolderType    @default(GA_POOL) @map("holder_type")

  // Pemegang saat ini (nullable = di GA pool)
  assignedToName String?       @map("assigned_to_name")
  assignedToId   String?       @map("assigned_to_id")
  assignedAt     DateTime?     @map("assigned_at")

  // Khusus kategori NOMOR_HP — SIM card fisik Indosat
  nomorIndosat   String?       @map("nomor_indosat")
  expiredDate    DateTime?     @map("expired_date")

  keterangan     String?       @db.Text
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  assignedTo     Employee?     @relation(fields: [assignedToId], references: [employeeId])
  histories      AssetHistory[]
  inspections    AssetInspection[]

  @@index([assignedToId], map: "assets_assigned_to_id_fkey")
  @@index([categoryId], map: "assets_category_id_fkey")

  @@map("assets")
}

model AssetHistory {
  id             String      @id @default(uuid())
  assetId        String      @map("asset_id")
  asset          Asset       @relation(fields: [assetId], references: [id], onDelete: Restrict)

  fromHolderType HolderType? @map("from_holder_type")
  fromName       String?     @map("from_name")
  toHolderType   HolderType  @map("to_holder_type")
  toName         String?     @map("to_name")

  // "assigned" | "returned" | "sent_to_maintenance" | "kondisi_changed" | "retired"
  action         String
  kondisiSaat    AssetKondisi @map("kondisi_saat")
  notes          String?      @db.Text

  performedBy    String       @map("performed_by") // employeeId GA
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("asset_histories")
}

// ─── Asset Inspection (Checklist Inspeksi GA) ────────────────────

model AssetInspection {
  id            String       @id @default(uuid())
  assetId       String       @map("asset_id")
  asset         Asset        @relation(fields: [assetId], references: [id], onDelete: Restrict)

  kondisiSaat   AssetKondisi @map("kondisi_saat")

  /// JSON: record of checklist items e.g. {"layar":true,"body":false}
  checklistJson String       @map("checklist_json") @db.Text

  notes         String?      @db.Text
  performedBy   String       @map("performed_by") // employeeId GA
  inspectedAt   DateTime     @default(now()) @map("inspected_at")

  @@index([assetId], map: "asset_inspections_asset_id_fkey")
  @@map("asset_inspections")
}
