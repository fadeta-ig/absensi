generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Employee {
  id           String  @id @default(uuid())
  employeeId   String  @unique @map("employee_id")
  name         String
  email        String  @unique
  phone        String
  departmentId String  @map("department_id")
  divisionId   String? @map("division_id")
  positionId   String  @map("position_id")

  departmentRel         Department                 @relation("EmployeeDepartment", fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  divisionRel           Division?                  @relation("EmployeeDivision", fields: [divisionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  positionRel           Position                   @relation("EmployeePosition", fields: [positionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  gender                String                     @default("Laki-Laki")
  faceDescriptor        String?                    @map("face_descriptor") @db.LongText
  joinDate              DateTime                   @map("join_date")
  totalLeave            Int                        @default(12) @map("total_leave")
  usedLeave             Int                        @default(0) @map("used_leave")
  avatarUrl             String?                    @map("avatar_url") @db.LongText
  isActive              Boolean                    @default(true) @map("is_active")
  statusChangedAt       DateTime?                  @map("status_changed_at")
  shiftId               String?                    @map("shift_id")
  bypassLocation        Boolean                    @default(false) @map("bypass_location")
  basicSalary           Float                      @default(0) @map("basic_salary")
  managerId             String?                    @map("manager_id")
  attendances           AttendanceRecord[]
  payrollComponents     EmployeePayrollComponent[]
  manager               Employee?                  @relation("Hierarchy", fields: [managerId], references: [employeeId])
  subordinates          Employee[]                 @relation("Hierarchy")
  shift                 WorkShift?                 @relation(fields: [shiftId], references: [id])
  leaves                LeaveRequest[]
  overtimes             OvertimeRequest[]
  payslips              PayslipRecord[]
  todos                 TodoItem[]
  visits                VisitReport[]
  locations             Location[]                 @relation("employeelocations")
  userAccount           UserAccount?
  assignedAssets        Asset[]
  attendanceCorrections AttendanceCorrection[]     @relation("CorrectionRequester")
  correctionApprovals   AttendanceCorrection[]     @relation("CorrectionApprover")
  letterRequests        LetterRequest[]
  statusHistories       EmployeeStatusHistory[]    @relation("EmployeeStatusSubject")
  assetTickets          AssetTicket[]
  simCards              SimCard[]
  documents             EmployeeDocument[]

  @@index([managerId], map: "employees_manager_id_fkey")
  @@index([shiftId], map: "employees_shift_id_fkey")
  @@index([isActive], map: "idx_employees_is_active")
  @@map("employees")
}

model UserAccount {
  id                String    @id @default(uuid())
  username          String    @unique @db.VarChar(100)
  displayName       String    @map("display_name")
  email             String    @unique
  passwordHash      String    @map("password_hash")
  isActive          Boolean   @default(true) @map("is_active")
  sessionVersion    Int       @default(0) @map("session_version")
  employeeId        String?   @unique @map("employee_id")
  lastLoginAt       DateTime? @map("last_login_at")
  passwordChangedAt DateTime? @map("password_changed_at")
  createdByUserId   String?   @map("created_by_user_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  employee            Employee?               @relation(fields: [employeeId], references: [employeeId], onDelete: SetNull, onUpdate: Cascade)
  creator             UserAccount?            @relation("UserCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdUsers        UserAccount[]           @relation("UserCreator")
  roles               UserRoleAssignment[]    @relation("UserRoles")
  roleAssignmentsMade UserRoleAssignment[]    @relation("RoleAssigner")
  auditLogs           AuditLog[]              @relation("UserAuditLogs")
  statusChanges       EmployeeStatusHistory[] @relation("EmployeeStatusActor")
  pushSubscriptions   PushSubscription[]
  assetHistories      AssetHistory[]          @relation("AssetHistoryActor")
  assetBastUploads    AssetBastDocument[]     @relation("AssetBastActor")
  assetInspections    AssetInspection[]       @relation("AssetInspectionActor")

  @@index([createdByUserId], map: "idx_user_accounts_created_by")
  @@index([isActive], map: "idx_user_accounts_is_active")
  @@map("user_accounts")
}

model Role {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(50)
  name        String
  description String?  @db.Text
  isSystem    Boolean  @default(true) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       UserRoleAssignment[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(100)
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model UserRoleAssignment {
  userId           String   @map("user_id")
  roleId           String   @map("role_id")
  assignedByUserId String?  @map("assigned_by_user_id")
  assignedAt       DateTime @default(now()) @map("assigned_at")

  user       UserAccount  @relation("UserRoles", fields: [userId], references: [id], onDelete: Cascade)
  role       Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)
  assignedBy UserAccount? @relation("RoleAssigner", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@id([userId, roleId])
  @@index([roleId], map: "idx_user_roles_role")
  @@index([assignedByUserId], map: "idx_user_roles_assigned_by")
  @@map("user_role_assignments")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId], map: "idx_role_permissions_permission")
  @@map("role_permissions")
}

model EmployeeStatusHistory {
  id                  String   @id @default(uuid())
  employeeId          String   @map("employee_id")
  wasActive           Boolean  @map("was_active")
  isActive            Boolean  @map("is_active")
  reason              String   @db.Text
  effectiveDate       DateTime @map("effective_date")
  changedByUserId     String?  @map("changed_by_user_id")
  changedByIdentifier String   @map("changed_by")
  changedByName       String?  @map("changed_by_name")
  changedByRole       String?  @map("changed_by_role")
  createdAt           DateTime @default(now()) @map("created_at")

  employee Employee     @relation("EmployeeStatusSubject", fields: [employeeId], references: [employeeId], onDelete: Restrict, onUpdate: Cascade)
  actor    UserAccount? @relation("EmployeeStatusActor", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([employeeId, createdAt], map: "idx_employee_status_history_subject_created")
  @@index([changedByUserId], map: "idx_employee_status_history_actor")
  @@map("employee_status_histories")
}

model AuditLog {
  id              String   @id @default(uuid())
  action          String // e.g. DELETE_PAYSLIP, APPROVE_OVERTIME
  entity          String // e.g. PAYSLIP, OVERTIME
  entityId        String?  @map("entity_id")
  details         String?  @db.LongText // JSON payload
  actorType       String   @default("USER") @map("actor_type")
  actorUserId     String?  @map("actor_user_id")
  actorIdentifier String   @map("performed_by")
  actorName       String?  @map("actor_name")
  actorRole       String?  @map("actor_role")
  createdAt       DateTime @default(now()) @map("created_at")

  user UserAccount? @relation("UserAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId], map: "idx_audit_logs_actor_user")
  @@index([actorIdentifier], map: "idx_audit_logs_actor_identifier")
  @@map("audit_logs")
}

model PushSubscription {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  endpoint  String      @unique @db.VarChar(500)
  p256dh    String      @db.Text
  auth      String      @db.Text
  createdAt DateTime    @default(now()) @map("created_at")
  user      UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "push_subscriptions_user_id_fkey")
  @@map("push_subscriptions")
}

model VisitReport {
  id            String    @id @default(uuid())
  employeeId    String    @map("employee_id")
  date          DateTime
  clockInTime   DateTime? @map("clock_in_time")
  clockOutTime  DateTime? @map("clock_out_time")
  clientName    String    @map("client_name")
  clientAddress String    @map("client_address") @db.Text
  purpose       String    @db.Text
  result        String?   @db.Text

  // Titik lokasi tujuan kunjungan (JSON: {lat, lng})
  visitLocation String? @map("visit_location") @db.LongText
  visitRadius   Float   @default(300) @map("visit_radius")

  // Lokasi GPS saat clock in & clock out (JSON: {lat, lng})
  clockInLocation  String? @map("clock_in_location") @db.LongText
  clockOutLocation String? @map("clock_out_location") @db.LongText

  // Foto bukti kunjungan (JSON array of base64 strings)
  clockInPhotos  String? @map("clock_in_photos") @db.LongText
  clockOutPhotos String? @map("clock_out_photos") @db.LongText

  // Status: draft | clocked_in | clocked_out
  status    String  @default("draft")
  notes     String? @db.Text
  hrChecked Boolean @default(false) @map("hr_checked")

  createdAt DateTime @default(now()) @map("created_at")
  employee  Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@index([employeeId], map: "visit_reports_employee_id_fkey")
  @@map("visit_reports")
}

model AttendanceRecord {
  id               String    @id @default(uuid())
  employeeId       String    @map("employee_id")
  date             DateTime
  clockIn          DateTime? @map("clock_in")
  clockOut         DateTime? @map("clock_out")
  clockInLocation  String?   @map("clock_in_location") @db.LongText
  clockOutLocation String?   @map("clock_out_location") @db.LongText
  clockInPhoto     String?   @map("clock_in_photo") @db.LongText
  clockOutPhoto    String?   @map("clock_out_photo") @db.LongText
  status           String    @default("present")
  notes            String?   @db.Text
  employee         Employee  @relation(fields: [employeeId], references: [employeeId], onDelete: Restrict)

  @@unique([employeeId, date])
  @@map("attendance_records")
}

model PayslipRecord {
  id          String        @id @default(uuid())
  employeeId  String        @map("employee_id")
  period      String
  basicSalary Float         @map("basic_salary")
  items       PayslipItem[]
  overtime    Float         @default(0)
  netSalary   Float         @map("net_salary")
  issuedDate  DateTime      @map("issued_date")
  notes       String?       @db.Text
  employee    Employee      @relation(fields: [employeeId], references: [employeeId], onDelete: Restrict)

  @@unique([employeeId, period])
  @@index([employeeId], map: "payslip_records_employee_id_fkey")
  @@map("payslip_records")
}

enum PayslipItemType {
  ALLOWANCE
  DEDUCTION
}

model PayslipItem {
  id        String          @id @default(uuid())
  payslipId String          @map("payslip_record_id")
  type      PayslipItemType
  name      String
  amount    Float

  payslipRecord PayslipRecord @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  @@index([payslipId], map: "idx_payslip_items_payslip_id")
  @@map("payslip_items")
}

enum AssessmentStatus {
  PENDING
  APPROVED
  REJECTED
}

model AttendanceCorrection {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  targetDate DateTime @map("target_date")

  proposedClockIn  DateTime? @map("proposed_clock_in")
  proposedClockOut DateTime? @map("proposed_clock_out")

  reason        String  @db.Text
  attachmentUrl String? @map("attachment_url")

  status            AssessmentStatus @default(PENDING)
  assignedManagerId String?          @map("assigned_manager_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee Employee  @relation("CorrectionRequester", fields: [employeeId], references: [employeeId], onDelete: Cascade)
  manager  Employee? @relation("CorrectionApprover", fields: [assignedManagerId], references: [employeeId])

  @@index([employeeId], map: "idx_attendance_corrections_employee_id")
  @@index([assignedManagerId], map: "idx_attendance_corrections_manager_id")
  @@map("attendance_corrections")
}

model WorkShift {
  id            String         @id @default(uuid())
  name          String
  isDefault     Boolean        @default(false) @map("is_default")
  earlyCheckIn  Int            @default(0) @map("early_check_in")
  earlyCheckOut Int            @default(0) @map("early_check_out")
  lateCheckIn   Int            @default(0) @map("late_check_in")
  lateCheckOut  Int            @default(0) @map("late_check_out")
  employees     Employee[]
  days          WorkShiftDay[]

  @@map("work_shifts")
}

model WorkShiftDay {
  id        String    @id @default(uuid())
  shiftId   String    @map("shift_id")
  dayOfWeek Int       @map("day_of_week")
  startTime String    @map("start_time")
  endTime   String    @map("end_time")
  isOff     Boolean   @default(false) @map("is_off")
  shift     WorkShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([shiftId, dayOfWeek])
  @@map("work_shift_days")
}

model LeaveRequest {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  type       String
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  reason     String   @db.Text
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")
  attachment String?  @db.LongText
  employee   Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Restrict)

  @@index([employeeId], map: "leave_requests_employee_id_fkey")
  @@map("leave_requests")
}

model NewsItem {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  category  String   @default("general")
  author    String
  createdAt DateTime @default(now()) @map("created_at")
  isPinned  Boolean  @default(false) @map("is_pinned")
  mediaName String?  @map("media_name")
  mediaUrl  String?  @map("media_url")

  @@map("news_items")
}

model TodoItem {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  text       String   @db.Text
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  employee   Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@index([employeeId], map: "todo_items_employee_id_fkey")
  @@map("todo_items")
}

model OvertimeRequest {
  id            String   @id @default(uuid())
  employeeId    String   @map("employee_id")
  date          DateTime
  startTime     DateTime @map("start_time")
  endTime       DateTime @map("end_time")
  hours         Float
  approvedHours Float?   @map("approved_hours")
  isHoliday     Boolean  @default(false) @map("is_holiday")
  overtimePay   Float    @default(0) @map("overtime_pay")
  reason        String   @db.Text
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")
  employee      Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Restrict)

  @@index([employeeId], map: "overtime_requests_employee_id_fkey")
  @@map("overtime_requests")
}

model Department {
  id          String     @id @default(uuid())
  name        String     @unique
  code        String?    @unique
  description String?    @db.Text
  divisionId  String     @map("division_id")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  division    Division   @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  employees   Employee[] @relation("EmployeeDepartment")

  @@index([divisionId], map: "departments_division_id_fkey")
  @@map("departments")
}

model Division {
  id          String       @id @default(uuid())
  name        String       @unique
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  departments Department[]
  employees   Employee[]   @relation("EmployeeDivision")

  @@map("divisions")
}

model Position {
  id        String     @id @default(uuid())
  name      String     @unique
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  employees Employee[] @relation("EmployeePosition")

  @@map("positions")
}

model PayrollComponent {
  id                 String                     @id @default(uuid())
  name               String                     @unique
  type               String
  defaultAmount      Float                      @default(0) @map("default_amount")
  isActive           Boolean                    @default(true) @map("is_active")
  description        String?                    @db.Text
  createdAt          DateTime                   @default(now()) @map("created_at")
  employeeComponents EmployeePayrollComponent[]

  @@map("payroll_components")
}

model EmployeePayrollComponent {
  id          String           @id @default(uuid())
  employeeId  String           @map("employee_id")
  componentId String           @map("component_id")
  amount      Float            @default(0)
  component   PayrollComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  employee    Employee         @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@unique([employeeId, componentId])
  @@index([componentId], map: "employee_payroll_components_component_id_fkey")
  @@map("employee_payroll_components")
}

model Location {
  id        String     @id @default(uuid())
  name      String     @unique
  latitude  Float
  longitude Float
  radius    Float      @default(100)
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  employees Employee[] @relation("employeelocations")

  @@map("locations")
}

// ─── Asset Management ──────────────────────────────────────────

model AssetCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  prefix    String
  createdAt DateTime @default(now()) @map("created_at")

  assets Asset[]

  @@map("asset_categories")
}

enum AssetKondisi {
  BAIK
  KURANG_BAIK
  RUSAK
}

enum AssetStatus {
  AVAILABLE // Di GA pool — siap dipinjamkan
  IN_USE // Sedang dipegang seseorang
  MAINTENANCE // Sedang diperbaiki
  RETIRED // Tidak layak pakai
  COMPANY_OWNED // Milik perusahaan (ex-lelang), hidden dari HR
}

enum HolderType {
  EMPLOYEE // Karyawan aktif
  FORMER_EMPLOYEE // Mantan karyawan (nama tetap disimpan)
  TEAM // Dipegang tim (Warehouse, Creative, dll)
  GA_POOL // Di brankas GA — aset bebas
  COMPANY_OWNED // Milik perusahaan
}

model Asset {
  id        String @id @default(uuid())
  assetCode String @unique @map("asset_code")
  name      String

  categoryId  String        @map("category_id")
  categoryRel AssetCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  serialNumber String? @map("serial_number")
  imei         String? @map("imei")
  manufacturer String?
  modelName    String? @map("model_name")

  purchaseDate   DateTime?    @map("purchase_date")
  purchasePrice  Float?       @map("purchase_price")
  warrantyExpiry DateTime?    @map("warranty_expiry")
  kondisi        AssetKondisi @default(BAIK)
  status         AssetStatus  @default(AVAILABLE)
  holderType     HolderType   @default(GA_POOL) @map("holder_type")

  // Pemegang saat ini (nullable = di GA pool)
  assignedToName String?   @map("assigned_to_name")
  assignedToId   String?   @map("assigned_to_id")
  assignedAt     DateTime? @map("assigned_at")

  keterangan String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  assignedTo   Employee?          @relation(fields: [assignedToId], references: [employeeId])
  histories    AssetHistory[]
  inspections  AssetInspection[]
  maintenances AssetMaintenance[]
  tickets      AssetTicket[]

  @@index([assignedToId], map: "assets_assigned_to_id_fkey")
  @@index([categoryId], map: "assets_category_id_fkey")
  @@fulltext([name, assetCode, serialNumber])
  @@map("assets")
}

model AssetHistory {
  id      String @id @default(uuid())
  assetId String @map("asset_id")
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Restrict)

  fromHolderType HolderType? @map("from_holder_type")
  fromName       String?     @map("from_name")
  toHolderType   HolderType  @map("to_holder_type")
  toName         String?     @map("to_name")

  // "assigned" | "returned" | "sent_to_maintenance" | "kondisi_changed" | "retired"
  action      String
  kondisiSaat AssetKondisi @map("kondisi_saat")
  notes       String?      @db.Text

  performedBy       String              @map("performed_by")
  performedByUserId String?             @map("performed_by_user_id")
  performedByUser   UserAccount?        @relation("AssetHistoryActor", fields: [performedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime            @default(now()) @map("created_at")
  bastDocuments     AssetBastDocument[]

  @@index([performedByUserId], map: "idx_asset_histories_actor")
  @@map("asset_histories")
}

// ─── Asset BAST (Berita Acara Serah Terima) ─────────────────────

model AssetBastDocument {
  id               String   @id @default(uuid())
  historyId        String   @map("history_id")
  fileData         Bytes    @map("file_data") @db.MediumBlob
  mimeType         String   @map("mime_type")
  fileName         String   @map("file_name")
  uploadedBy       String   @map("uploaded_by")
  uploadedByUserId String?  @map("uploaded_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  history        AssetHistory @relation(fields: [historyId], references: [id], onDelete: Cascade)
  uploadedByUser UserAccount? @relation("AssetBastActor", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([historyId], map: "idx_bast_documents_history_id")
  @@index([uploadedByUserId], map: "idx_bast_documents_actor")
  @@map("asset_bast_documents")
}

// ─── Asset Inspection (Checklist Inspeksi GA) ────────────────────

model AssetInspection {
  id      String @id @default(uuid())
  assetId String @map("asset_id")
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Restrict)

  kondisiSaat AssetKondisi @map("kondisi_saat")

  checklistItems InspectionChecklistItem[]

  notes             String?      @db.Text
  performedBy       String       @map("performed_by")
  performedByUserId String?      @map("performed_by_user_id")
  performedByUser   UserAccount? @relation("AssetInspectionActor", fields: [performedByUserId], references: [id], onDelete: SetNull)
  inspectedAt       DateTime     @default(now()) @map("inspected_at")

  @@index([assetId], map: "asset_inspections_asset_id_fkey")
  @@index([performedByUserId], map: "idx_asset_inspections_actor")
  @@map("asset_inspections")
}

model InspectionChecklistItem {
  id           String  @id @default(uuid())
  inspectionId String  @map("inspection_id")
  itemName     String
  isPass       Boolean @default(true)
  notes        String? @db.Text

  inspection AssetInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId], map: "idx_inspection_items_inspection_id")
  @@map("inspection_checklist_items")
}

// ─── Asset Maintenance (Log Servis & Vendor) ─────────────────────

model AssetMaintenance {
  id               String    @id @default(uuid())
  assetId          String    @map("asset_id")
  vendorName       String    @map("vendor_name")
  cost             Float     @default(0)
  startDate        DateTime  @map("start_date")
  estimatedEndDate DateTime? @map("estimated_end_date")
  actualEndDate    DateTime? @map("actual_end_date")
  status           String    @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, CANCELLED
  notes            String?   @db.Text
  attachmentUrl    String?   @map("attachment_url") // Opsional: Bukti Invoice/Nota
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId], map: "idx_asset_maintenance_asset_id")
  @@map("asset_maintenances")
}

// ─── Employee Self-Service ────────────────────────────────────────

enum LetterType {
  SK_KERJA
  KET_PENGHASILAN
  KET_MASIH_BEKERJA
  BPJS
}

enum LetterStatus {
  PENDING // Baru diajukan
  PROCESSING // Sedang diproses HR
  READY // Siap diambil
  REJECTED // Ditolak
}

model LetterRequest {
  id         String       @id @default(uuid())
  employeeId String       @map("employee_id")
  type       LetterType
  purpose    String       @db.Text
  status     LetterStatus @default(PENDING)
  notes      String?      @db.Text
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@index([employeeId], map: "idx_letter_requests_employee_id")
  @@map("letter_requests")
}

// ─── Asset Ticketing (Employee <-> GA) ─────────────────────────

enum TicketType {
  NEW_REQUEST
  DAMAGE_REPORT
}

enum TicketStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  RESOLVED
}

model AssetTicket {
  id          String       @id @default(uuid())
  ticketCode  String       @unique @map("ticket_code")
  employeeId  String       @map("employee_id")
  type        TicketType
  assetId     String?      @map("asset_id")
  title       String
  description String       @db.Text
  status      TicketStatus @default(PENDING)
  gaResponse  String?      @map("ga_response") @db.Text
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Restrict)
  asset    Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([employeeId], map: "asset_tickets_employee_id_fkey")
  @@index([assetId], map: "asset_tickets_asset_id_fkey")
  @@map("asset_tickets")
}

// ─── SIM Cards ──────────────────────────────────────────────────

model SimCard {
  id           String    @id @default(uuid())
  phoneNumber  String    @unique @map("phone_number")
  provider     String    @default("Indosat")
  expiredDate  DateTime? @map("expired_date")
  assignedToId String?   @map("assigned_to_id")
  assignedAt   DateTime? @map("assigned_at")
  notes        String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  assignedTo Employee? @relation(fields: [assignedToId], references: [employeeId], onDelete: SetNull)

  @@index([assignedToId])
  @@map("sim_cards")
}

// ─── Employee Documents ─────────────────────────────────────────

enum DocumentType {
  KTP
  NPWP
  BPJS_KES
  BPJS_TK
  IJAZAH
  KARTU_KELUARGA
  OTHER
}

model EmployeeDocument {
  id         String       @id @default(uuid())
  employeeId String       @map("employee_id")
  type       DocumentType
  title      String
  fileUrl    String       @map("file_url")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_documents")
}
