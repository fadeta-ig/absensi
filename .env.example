# Copy file ini menjadi .env pada setiap environment.
# Jangan commit nilai secret asli ke repository.

# Database MariaDB/MySQL
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

# Auth
# Wajib diisi. Minimal 16 karakter, disarankan 32+ karakter acak.
JWT_SECRET="replace-with-a-long-random-secret"

# Optional. Jika kosong, aplikasi memakai JWT_SECRET sebagai fallback untuk enkripsi PII.
PII_ENCRYPTION_KEY=""

# Runtime
# Untuk production biasanya diset oleh platform/deployment.
NODE_ENV="production"

# Public app URL untuk QR/public link dan client-side URL.
NEXT_PUBLIC_APP_URL="https://hris.example.com"

# Optional fallback URL yang dibaca QR route jika NEXT_PUBLIC_APP_URL kosong.
NEXTAUTH_URL="https://hris.example.com"

# Email SMTP, opsional. Isi jika fitur kirim password/email dipakai.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="WIG Attendance <noreply@example.com>"

# Face recognition threshold, opsional. Default kode: 0.92.
NEXT_PUBLIC_FACE_THRESHOLD="0.92"

# Web push notification, opsional.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Cron endpoint protection.
CRON_SECRET="replace-with-a-long-random-cron-secret"
